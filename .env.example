# Copy to .env and fill in. Never commit .env.

GEMINI_API_KEY=
# Cost-efficient default; override with a current Flash-Lite id from:
# https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.0-flash-lite

# Optional: where SQLite and runtime files live (default: <project>/data)
# ADA_DATA_DIR=/path/to/data

# Max model legs per user turn (tool follow-ups included). Default 12.
# ADA_MAX_TOOL_ROUNDS=12

# Hard cap on summed usage_ledger tokens (input+output) per task/session; turns abort when exceeded.
# ADA_MAX_SESSION_TOKENS=50000

# Allowlisted shell output cap and timeout (seconds).
# ADA_SHELL_MAX_OUTPUT_BYTES=65536
# ADA_SHELL_TIMEOUT_SEC=60

# Stream watchdogs (0 = disable that limit).
# ADA_STREAM_CHUNK_IDLE_SEC=120
# ADA_STREAM_LEG_MAX_SEC=600

# Reparent live rows whose parent was tombstoned (1=yes, 0=no).
# ADA_REWIRE_AFTER_TOMBSTONE=1

# Task clipboard: read_task_plan / write_task_plan (tasks.plan_json). Chat + daemon.
# ADA_ENABLE_PLAN_TOOLS=1

# Sandboxed workspace files (read_workspace_file / write_workspace_file). Off by default.
# Paths must resolve under ADA_FILE_SANDBOX_ROOTS (comma-separated); empty = project root only.
# ADA_ENABLE_FILE_TOOLS=1
# ADA_FILE_SANDBOX_ROOTS=
# ADA_FILE_MAX_READ_BYTES=524288
# ADA_FILE_MAX_WRITE_BYTES=262144

# Memory tools in chat (append_master_section / append_soul_fragment). Dream job: `ada dream`.
# ADA_ENABLE_MEMORY_TOOLS=1
# ADA_MEMORY_MAX_APPEND_BYTES=8192
# ADA_MEMORY_MAX_FILE_BYTES=524288
# ADA_DREAM_MAX_SOUL_BYTES=1024
# ADA_DREAM_MAX_MESSAGES=60
