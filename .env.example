# Copy to .env and fill in. Never commit .env.

GEMINI_API_KEY=
# Cost-efficient default (2.5 Flash-Lite). Override with e.g. gemini-2.5-flash from:
# https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: where SQLite and runtime files live (default: <project>/data)
# ADA_DATA_DIR=/path/to/data

# Max model legs per user turn (tool follow-ups included). Default 12.
# ADA_MAX_TOOL_ROUNDS=12

# Hard cap on summed usage_ledger tokens (input+output) per task/session; turns abort when exceeded.
# ADA_MAX_SESSION_TOKENS=50000

# Allowlisted shell output cap and timeout (seconds).
# ADA_SHELL_MAX_OUTPUT_BYTES=65536
# ADA_SHELL_TIMEOUT_SEC=60

# Stream watchdogs (0 = disable that limit).
# ADA_STREAM_CHUNK_IDLE_SEC=120
# ADA_STREAM_LEG_MAX_SEC=600

# Verbose per-chunk Gemini stream diagnostics on stderr (1=yes). Use when debugging empty legs / tool calls.
# ADA_DEBUG_STREAM=0

# Reparent live rows whose parent was tombstoned (1=yes, 0=no).
# ADA_REWIRE_AFTER_TOMBSTONE=1

# Task clipboard: read_task_plan / write_task_plan (tasks.plan_json). Chat + daemon.
# ADA_ENABLE_PLAN_TOOLS=1

# Cross-session: read_goal_task_view — read another goal task's outcome from SQLite (chat + daemon).
# ADA_ENABLE_GOAL_RECALL_TOOL=1

# Sandboxed workspace files (list_workspace_directory / read / write). Off by default.
# Paths must resolve under ADA_FILE_SANDBOX_ROOTS (comma-separated); empty = project root only.
# Default deny prefixes always include ADA_DATA_DIR and memory/; the project tree is also denied
# when the sandbox root is a parent of the ADA repo (e.g. home-wide roots). Basenames .env, id_rsa, *.pem are denied.
# ADA_ENABLE_FILE_TOOLS=1
# ADA_FILE_SANDBOX_ROOTS=
# ADA_FILE_MAX_READ_BYTES=524288
# ADA_FILE_MAX_WRITE_BYTES=262144
# ADA_FILE_MAX_LIST_ENTRIES=200
# Extra denied path prefixes (comma-separated). Example for SSH: /home/you/.ssh
# ADA_FILE_DENY_PREFIXES=
# Optional file: one absolute path per line, # comments (like shell_allowlist.txt). Relative paths are under project root.
# ADA_FILE_DENYLIST_FILE=
# Extra forbidden basenames (comma-separated), in addition to .env / id_rsa / *.pem.
# ADA_FILE_DENY_BASENAMES=
# Log denied file-tool paths to action_log as file_access_denied (1=yes, 0=no). Default 1.
# ADA_FILE_AUDIT_DENIALS=1

# Memory tools in chat (append_master_section / append_soul_fragment). Dream job: `ada dream`.
# ADA_ENABLE_MEMORY_TOOLS=1
# ADA_MEMORY_MAX_APPEND_BYTES=8192
# ADA_MEMORY_MAX_FILE_BYTES=524288
# ADA_DREAM_MAX_SOUL_BYTES=1024
# ADA_DREAM_MAX_MESSAGES=60

# Web tools (web_search via Serper, fetch_url_text via Jina Reader or httpx). Off by default (cost).
# ADA_ENABLE_WEB_TOOLS=0
# ADA_SERPER_API_KEY=  (or SERPER_API_KEY)
# ADA_WEB_SEARCH_MAX_RESULTS=10
# ADA_WEB_SEARCH_TIMEOUT_SEC=30
# ADA_WEB_FETCH_MODE=jina
# ADA_WEB_FETCH_MAX_URLS=3
# ADA_WEB_FETCH_MAX_CHARS=65536
# ADA_WEB_FETCH_MAX_BYTES=524288
# ADA_WEB_FETCH_TIMEOUT_SEC=45
# Optional: comma-separated host glob patterns (e.g. *.python.org,github.com)
# ADA_WEB_FETCH_HOST_ALLOWLIST=
# ADA_JINA_READER_URL=https://r.jina.ai/
# JINA_READER_BASE_URL=https://r.jina.ai/
# ADA_JINA_API_KEY=

# Read-only: list web_sources rows for current session (Phase B). Off by default.
# ADA_ENABLE_WEB_SOURCES_TOOL=0

# Knowledge layer: search_knowledge, record_synthesis, add_knowledge_source (Gemini tools). Off by default in code; set 1 for operator-ready chat/daemon.
# ADA_ENABLE_KNOWLEDGE_TOOLS=1
# Optional: comma-separated hostnames allowed for add_knowledge_source (empty = any https/http host).
# ADA_KNOWLEDGE_FEED_HOST_ALLOWLIST=
# Tool payload caps to reduce token bleed in chat/daemon responses.
# ADA_KNOWLEDGE_TOOL_MAX_RESULTS=8
# ADA_KNOWLEDGE_TOOL_EXCERPT_CHARS=1200

# Register an RSS URL in SQLite, then fetch with ingest-rss:
#   ada add-rss-source https://example.com/feed.xml --label "My feed"
# Offline RSS ingest (`ada ingest-rss`): fetch feeds listed in knowledge_sources (kind=rss).
# ADA_INGEST_RSS_MAX_ITEMS=50
# ADA_INGEST_RSS_MAX_RESPONSE_BYTES=2000000
# ADA_INGEST_RSS_TIMEOUT_SEC=45

# Per-item expiry: set N>0 so new ingested rows get expires_at = now + N days (ISO UTC).
# ADA_KNOWLEDGE_DEFAULT_RETENTION_DAYS=

# `ada triage`: score unscored knowledge_items (NZ economy/markets 1–10, JSON). Requires GEMINI_API_KEY.
# ADA_TRIAGE_MODEL=gemini-2.5-flash-lite
# ADA_TRIAGE_BATCH_SIZE=20
# Enqueue a daemon goal when impact_score >= this (1–10; default 6).
# ADA_TRIAGE_DEEP_DIVE_MIN_SCORE=6
# Daily cap for Tier-2 lead goals (score 6-7). 0 disables Tier-2 enqueues.
# ADA_TRIAGE_LEAD_DAILY_CAP=10

# Optional LLM gate during ingest (title+summary only, JSON). Requires GEMINI_API_KEY when enabled.
# ADA_INGEST_GATEKEEPER=0
# ADA_INGEST_GATE_MODEL=gemini-2.5-flash-lite
# ADA_INGEST_GATE_MAX_OUTPUT_TOKENS=512

# Gemini embeddings for semantic/hybrid search (optional; uses GEMINI_API_KEY). Ingest writes vectors when enabled.
# ADA_KNOWLEDGE_EMBEDDINGS=0
# ADA_KNOWLEDGE_EMBEDDING_MODEL=gemini-embedding-001
# ADA_KNOWLEDGE_EMBEDDING_DIM=768
# ADA_KNOWLEDGE_EMBEDDING_MIN_COSINE=0.25
